{
  "name": "supportsfusd",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "npm run migrate-check && next dev",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "migrate-check": "prisma migrate diff --from-schema-datamodel=prisma/schema.prisma --to-schema-datasource=prisma/schema.prisma",
    "build": "prisma migrate reset --force && next build",
    "dbpush": "prisma db push",
    "seed": "prisma db seed",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier . --write",
    "image-sync": "tsx prisma/image-sync.ts",
    "data-sync": "tsx prisma/data-sync.ts"
  },
  "dependencies": {
    "@emailjs/browser": "^4.3.3",
    "@prisma/client": "^5.13.0",
    "@reduxjs/toolkit": "^2.9.0",
    "@vercel/postgres": "^0.7.2",
    "dotenv": "^17.3.1",
    "image-size": "^2.0.1",
    "mapbox-gl": "^2.15.0",
    "next": "^16.1.6",
    "posthog-js": "^1.262.0",
    "posthog-node": "^5.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^4.11.0",
    "react-modal": "^3.16.1",
    "sharp": "^0.34.3",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^21.1.7",
    "@types/mapbox-gl": "^2.7.14",
    "@types/node": "^20.5.9",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@types/react-modal": "^3.16.3",
    "@types/supercluster": "^7.1.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "address": "^2.0.2",
    "autoprefixer": "10.4.15",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "file-loader": "^6.2.0",
    "globals": "^17.4.0",
    "googleapis": "^148.0.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^25.0.1",
    "openai": "^4.71.1",
    "postcss": "8.4.29",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "prisma": "^5.13.0",
    "tailwindcss": "3.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.2.2",
    "vercel": "^33.5.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "engines": {
    "node": "22.x"
  }
}
